# Optional server-side fallback for the AI score, draft, profile, and learning routes.
# For local MVP use, keys and request URLs can also be configured from Settings and stored in the local SQLite settings record.
CODEPROXY_API_KEY=
CODEPROXY_AI_MODEL=gpt-5.5
CODEPROXY_AI_ENDPOINT=https://codeproxy.dev/v1/responses
CODEPROXY_GROK_ENDPOINT=https://codeproxy.dev/v1/messages

# Optional per-task overrides.
CODEPROXY_SCORE_MODEL=gpt-5.5
CODEPROXY_DRAFT_MODEL=gpt-5.5
CODEPROXY_PROFILE_MODEL=gpt-5.5
CODEPROXY_MEMORY_MODEL=gpt-5.5
